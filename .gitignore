# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Test/cache artifacts
.pytest_cache/
.mypy_cache/
.uv-cache/
pytest-cache-files-*/
.pytest_cache_local/

# Virtual environments
.venv/
venv/
env/

# Local outputs
analysis_runs/
analysis_output*/
results/
artifacts/ui_preview/
*.log

# PyInstaller build artifacts
build/
dist/
*.spec.bak

# OS/editor artifacts
.DS_Store
Thumbs.db
NUL

# Git worktrees (isolated development branches)
.worktrees/
.tmp/
tmp*/

# Config presets use an allowlist: ignore all local presets by default,
# then explicitly unignore only productized presets that should be versioned.
configs/*.yaml
!configs/Tissue_knn_rsd050_marker_verify.yaml
